@model TechMoveGLMS.Models.Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="dashboard-header">
    <h2>Delete Client</h2>
</div>

<div class="danger-card">
    <h3><i class="fa-solid fa-triangle-exclamation"></i> Confirm Deletion</h3>
    <p style="color:#6b7280; margin-bottom:20px;">
        This action is permanent. Note: deletion will be blocked by the database if this client
        has existing contracts. Remove or reassign their contracts first.
    </p>

    <div class="detail-row">
        <span class="detail-label">Company Name</span>
        <span class="detail-value" style="font-weight:600;">@Model.Name</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Billing Email</span>
        <span class="detail-value">@Model.ContactEmail</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Region</span>
        <span class="detail-value">@Model.Region</span>
    </div>
</div>

<div class="form-actions" style="border:none; padding-top:0; margin-top:16px;">
    <form asp-action="Delete" style="display:inline;">
        <input type="hidden" asp-for="ClientId" />
        <button type="submit" class="btn-danger">
            <i class="fa-solid fa-trash"></i> Yes, Delete Permanently
        </button>
    </form>
    <a asp-action="Index" class="btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Cancel
    </a>
</div>
