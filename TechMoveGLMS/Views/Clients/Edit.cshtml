@model TechMoveGLMS.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="dashboard-header">
    <h2>Edit Client</h2>
</div>

<div class="glass-card form-container-small">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input type="hidden" asp-for="ClientId" />

        <div class="form-group">
            <label asp-for="Name">Company Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. Acme Logistics" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ContactEmail">Billing Email</label>
            <input asp-for="ContactEmail" class="form-control" type="email" />
            <span asp-validation-for="ContactEmail" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Region">Operating Region</label>
            <select asp-for="Region" class="form-control">
                <option value="">-- Select a Region --</option>
                <option value="North America">North America</option>
                <option value="Europe (EU)">Europe (EU)</option>
                <option value="Asia Pacific">Asia Pacific</option>
                <option value="Africa">Africa</option>
                <option value="South America">South America</option>
                <option value="Middle East">Middle East</option>
            </select>
            <span asp-validation-for="Region" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <input type="submit" value="Save Changes" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
