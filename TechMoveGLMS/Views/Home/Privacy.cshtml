@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="dashboard-header">
    <h2>Privacy Policy</h2>
</div>

<div class="glass-card" style="max-width: 800px;">
    <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:12px;">Data Collection & Use</h3>
    <p style="color:#6b7280; line-height:1.7; margin-bottom:16px;">
        TechMove GLMS collects and processes logistics data — including client details, contract records,
        and service request information — solely for the purpose of managing freight coordination operations.
        All data is stored securely and is not shared with third parties without consent.
    </p>

    <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:12px;">Currency Data</h3>
    <p style="color:#6b7280; line-height:1.7; margin-bottom:16px;">
        Live exchange rates are fetched from a third-party API (ExchangeRate-API) for display purposes only.
        Rates are not stored beyond the session.
    </p>

    <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:12px;">File Uploads</h3>
    <p style="color:#6b7280; line-height:1.7; margin-bottom:16px;">
        Signed agreement PDF files are stored on the application server and are accessible only to
        authorised system administrators.
    </p>

    <div style="margin-top:24px;">
        <a href="/" class="btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
