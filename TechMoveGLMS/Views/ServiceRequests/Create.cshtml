@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Raise Service Request";
}

<div class="dashboard-header">
    <h2>Raise Service Request</h2>
</div>

<div class="glass-card form-container-small">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="ContractId">Contract</label>
            <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId" required>
                <option value="">-- Select Contract --</option>
            </select>
            <span asp-validation-for="ContractId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description">Description</label>
            <input asp-for="Description" class="form-control"
                   placeholder="Describe the service required..." required />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Live Currency Calculator -->
        <div class="currency-calculator-box">
            <div class="currency-inputs">
                <div class="input-wrapper">
                    <label>Cost in USD ($)</label>
                    <input asp-for="OriginalCostUSD" id="usdInput" class="form-control"
                           type="number" step="0.01" min="0"
                           placeholder="Enter USD amount" required />
                    <span asp-validation-for="OriginalCostUSD" class="text-danger"></span>
                </div>
                <div class="input-wrapper">
                    <label>Live ZAR Estimate (R)</label>
                    <input id="zarPreview" class="form-control read-only-input"
                           type="text" readonly placeholder="Fetching rate..." />
                </div>
            </div>
            <p id="rateLabel" class="rate-label">
                <i class="fa-solid fa-spinner fa-spin"></i> Fetching current exchange rate...
            </p>
        </div>

        <div class="form-actions">
            <input type="submit" value="Submit Request" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            const usdInput = document.getElementById("usdInput");
            const zarPreview = document.getElementById("zarPreview");
            const rateLabel = document.getElementById("rateLabel");

            let exchangeRate = null;

            // Fetch live rates from a reliable, free exchange rate API
            try {
                const response = await fetch("https://open.er-api.com/v6/latest/USD");
                if (!response.ok) throw new Error("Failed to fetch rates");

                const data = await response.json();
                exchangeRate = data.rates.ZAR;

                // Update the UI text to show the active rate
                rateLabel.innerHTML = `<i class="fa-solid fa-circle-check text-success"></i> 1 USD = R ${exchangeRate.toFixed(2)} ZAR`;
                zarPreview.placeholder = "0.00";

                // Trigger calculation if a value was pre-filled
                calculateConversion();
            } catch (error) {
                console.error("Currency Fetch Error:", error);
                rateLabel.innerHTML = `<i class="fa-solid fa-circle-exclamation text-danger"></i> Could not update live rate. Using fallback (1 USD = R18.50)`;
                exchangeRate = 18.50; // Secure UI fallback rate
                zarPreview.placeholder = "0.00";
            }

            // Listen for typing events to calculate on the fly
            usdInput.addEventListener("input", calculateConversion);

            function calculateConversion() {
                const usdValue = parseFloat(usdInput.value);
                if (!isNaN(usdValue) && exchangeRate) {
                    const totalZar = usdValue * exchangeRate;
                    // Format with thousands separators and 2 decimal points
                    zarPreview.value = "R " + totalZar.toLocaleString("en-ZA", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                } else {
                    zarPreview.value = "";
                }
            }
        });
    </script>
}
