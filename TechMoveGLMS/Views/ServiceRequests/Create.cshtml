@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Raise Service Request";
}

<div class="dashboard-header" style="margin-bottom: 20px;">
    <h2>Raise Service Request</h2>
</div>

<div class="glass-card form-container-small">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="ContractId" class="control-label">Contract ID</label>
            <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId"></select>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <input asp-for="Description" class="form-control" required />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="currency-calculator-box">
            <div class="currency-inputs">
                <div class="input-wrapper">
                    <label>Cost in USD ($)</label>
                    <input asp-for="OriginalCostUSD" id="usdInput" class="form-control" type="number" step="0.01" placeholder="Enter USD amount" required />
                </div>
                <div class="input-wrapper">
                    <label>Live ZAR Estimate (R)</label>
                    <input id="zarPreview" class="form-control read-only-input" type="text" readonly placeholder="Calculating..." />
                </div>
            </div>
            <p id="rateLabel" class="rate-label">Fetching current exchange rate...</p>
        </div>

        <div class="form-group" style="margin-top: 20px;">
            <input type="submit" value="Submit Request" class="btn-primary" style="width: 100%;" />
        </div>
    </form>
</div>

<div>
    <a asp-action="Index" style="display:inline-block; margin-top:15px;">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}