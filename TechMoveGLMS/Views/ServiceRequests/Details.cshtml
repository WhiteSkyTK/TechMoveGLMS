@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Service Request Details";
}

<div class="dashboard-header">
    <h2>Service Request Details</h2>
    <a asp-action="Edit" asp-route-id="@Model.RequestId" class="btn-primary">
        <i class="fa-solid fa-pen-to-square"></i> Edit
    </a>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">Request ID</span>
        <span class="detail-value">#@Model.RequestId</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Contract</span>
        <span class="detail-value">Contract #@Model.Contract?.ContractId</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Description</span>
        <span class="detail-value">@Model.Description</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Original Cost</span>
        <span class="detail-value" style="font-weight:700; color:var(--primary-color);">
            $ @Model.OriginalCostUSD.ToString("N2") USD
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Converted Cost</span>
        <span class="detail-value" style="font-weight:700; color:#10b981;">
            R @Model.ConvertedCostZAR.ToString("N2") ZAR
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">
            @{
                var cls = Model.Status switch
                {
                    "Approved" => "badge-active",
                    "Rejected" => "badge-expired",
                    "In Progress" => "badge-draft",
                    "Completed" => "badge-active",
                    _ => "badge-pending"
                };
            }
            <span class="status-badge @cls">@Model.Status</span>
        </span>
    </div>
</div>

<div class="form-actions" style="border:none; padding-top:0; margin-top:16px;">
    <a asp-action="Index" class="btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Back to Requests
    </a>
    <a asp-action="Delete" asp-route-id="@Model.RequestId" class="btn-danger">
        <i class="fa-solid fa-trash"></i> Delete
    </a>
</div>
