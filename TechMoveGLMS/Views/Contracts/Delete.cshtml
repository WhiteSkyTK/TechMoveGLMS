@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<div class="dashboard-header">
    <h2>Delete Contract</h2>
</div>

<div class="danger-card">
    <h3><i class="fa-solid fa-triangle-exclamation"></i> Confirm Deletion</h3>
    <p style="color:#6b7280; margin-bottom:20px;">
        This will permanently remove the contract and cannot be undone.
        Any linked service requests will also be affected.
    </p>

    <div class="detail-row">
        <span class="detail-label">Client</span>
        <span class="detail-value" style="font-weight:600;">@Model.Client?.Name</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Start Date</span>
        <span class="detail-value">@Model.StartDate.ToString("dd MMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">End Date</span>
        <span class="detail-value">@Model.EndDate.ToString("dd MMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">@Model.Status</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Service Level</span>
        <span class="detail-value">@Model.Level</span>
    </div>
</div>

<div class="form-actions" style="border:none; padding-top:0; margin-top:16px;">
    <form asp-action="Delete" style="display:inline;">
        <input type="hidden" asp-for="ContractId" />
        <button type="submit" class="btn-danger">
            <i class="fa-solid fa-trash"></i> Yes, Delete Permanently
        </button>
    </form>
    <a asp-action="Index" class="btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Cancel
    </a>
</div>
