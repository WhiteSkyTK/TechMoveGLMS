@model IEnumerable<TechMoveGLMS.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
}

<div class="dashboard-header">
    <h2>Manage Contracts</h2>
    <a asp-action="Create" class="btn-primary">
        <i class="fa-solid fa-plus"></i> Issue New Contract
    </a>
</div>

<!-- Search / Filter Panel -->
<div class="glass-card" style="margin-bottom:20px; background:#f9fafb;">
    <form asp-action="Index" method="get"
          style="display:flex; gap:15px; align-items:flex-end; flex-wrap:wrap;">
        <div>
            <label style="font-weight:700; font-size:0.82rem; display:block; margin-bottom:4px;">
                Start Date
            </label>
            <input type="date" name="startDate" value="@ViewBag.StartDate"
                   class="form-control" style="width:auto;" />
        </div>
        <div>
            <label style="font-weight:700; font-size:0.82rem; display:block; margin-bottom:4px;">
                End Date
            </label>
            <input type="date" name="endDate" value="@ViewBag.EndDate"
                   class="form-control" style="width:auto;" />
        </div>
        <div>
            <label style="font-weight:700; font-size:0.82rem; display:block; margin-bottom:4px;">
                Status
            </label>
            <select name="searchStatus" class="form-control" style="width:auto;">
                <option value="">-- All Statuses --</option>
                <option value="0" selected="@(ViewBag.SearchStatus?.ToString() == "0")">Draft</option>
                <option value="1" selected="@(ViewBag.SearchStatus?.ToString() == "1")">Active</option>
                <option value="2" selected="@(ViewBag.SearchStatus?.ToString() == "2")">OnHold</option>
                <option value="3" selected="@(ViewBag.SearchStatus?.ToString() == "3")">Expired</option>
            </select>
        </div>
        <div style="display:flex; gap:8px;">
            <button type="submit" class="btn-primary">
                <i class="fa-solid fa-magnifying-glass"></i> Filter
            </button>
            <a asp-action="Index" class="btn-secondary">Clear</a>
        </div>
    </form>
</div>

<!-- Contracts Table -->
<div class="glass-card">
    <table class="table">
        <thead>
            <tr>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Level</th>
                <th>Agreement</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight:600;">@item.Client?.Name</td>
                    <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                    <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                    <td>
                        @{
                            var cls = item.Status switch
                            {
                                TechMoveGLMS.Models.ContractStatus.Active => "badge-active",
                                TechMoveGLMS.Models.ContractStatus.Draft => "badge-draft",
                                TechMoveGLMS.Models.ContractStatus.Expired => "badge-expired",
                                TechMoveGLMS.Models.ContractStatus.OnHold => "badge-onhold",
                                _ => "badge-draft"
                            };
                        }
                        <span class="status-badge @cls">@item.Status</span>
                    </td>
                    <td>@item.Level</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.SignedAgreementFilePath))
                        {
                            <a href="@item.SignedAgreementFilePath" target="_blank"
                               style="color:#10b981; font-weight:600;">
                                <i class="fa-solid fa-file-pdf"></i> View PDF
                            </a>
                        }
                        else
                        {
                            <span style="color:var(--text-light);">No file</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ContractId"
                           style="color:var(--primary-color); margin-right:10px;">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                        <a asp-action="Details" asp-route-id="@item.ContractId"
                           style="color:#6b7280; margin-right:10px;">
                            <i class="fa-solid fa-eye"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ContractId"
                           style="color:#ef4444;">
                            <i class="fa-solid fa-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div style="text-align:center; padding:50px 0; color:var(--text-light);">
            <i class="fa-solid fa-file-contract" style="font-size:2.5rem; display:block; margin-bottom:12px;"></i>
            No contracts match your filter. Try clearing the search.
        </div>
    }
</div>
