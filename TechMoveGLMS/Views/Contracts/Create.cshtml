@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Issue New Contract";
}

<div class="dashboard-header">
    <h2>Issue New Contract</h2>
</div>

<div class="glass-card form-container">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="ClientId">Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"
                        required>
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Level">Service Level</label>
                <select asp-for="Level" class="form-control">
                    <option value="0">Standard</option>
                    <option value="1">Express</option>
                    <option value="2">Hazardous</option>
                </select>
                <span asp-validation-for="Level" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StartDate">Start Date</label>
                <input asp-for="StartDate" class="form-control" type="date" required />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EndDate">End Date</label>
                <input asp-for="EndDate" class="form-control" type="date" required />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status">Initial Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="0">Draft</option>
                    <option value="1">Active</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        </div>

        <!-- PDF Upload Drop Zone -->
        <div class="form-group" style="margin-top:8px;">
            <label>Signed Agreement (PDF only)</label>
            <div class="upload-zone" id="drop-zone">
                <i class="fa-solid fa-cloud-arrow-up icon-large"></i>
                <p>Drag and drop your PDF here</p>
                <p class="text-muted">or click anywhere in this box to browse</p>
                <input type="file" id="fileInput" name="pdfFile"
                       accept="application/pdf" class="hidden-input" />
                <div id="file-name-display" class="file-success-msg hidden"></div>
            </div>
            <span id="file-error" class="file-error-msg hidden">
                <i class="fa-solid fa-circle-exclamation"></i>
                Only .pdf files are accepted. Please select a valid file.
            </span>
        </div>

        <div class="form-actions">
            <input type="submit" value="Create Contract" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
