@model TechMoveGLMS.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="dashboard-header">
    <h2>Contract Details</h2>
    <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn-primary">
        <i class="fa-solid fa-pen-to-square"></i> Edit
    </a>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">Contract ID</span>
        <span class="detail-value">#@Model.ContractId</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Client</span>
        <span class="detail-value">
            <span style="font-weight:600;">@Model.Client?.Name</span>
            <small style="color:#6b7280; display:block; margin-top:2px;">
                @Model.Client?.ContactEmail
            </small>
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Start Date</span>
        <span class="detail-value">@Model.StartDate.ToString("dd MMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">End Date</span>
        <span class="detail-value">@Model.EndDate.ToString("dd MMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">
            @{
                var cls = Model.Status switch
                {
                    TechMoveGLMS.Models.ContractStatus.Active => "badge-active",
                    TechMoveGLMS.Models.ContractStatus.Draft => "badge-draft",
                    TechMoveGLMS.Models.ContractStatus.Expired => "badge-expired",
                    TechMoveGLMS.Models.ContractStatus.OnHold => "badge-onhold",
                    _ => "badge-draft"
                };
            }
            <span class="status-badge @cls">@Model.Status</span>
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Service Level</span>
        <span class="detail-value">@Model.Level</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Signed Agreement</span>
        <span class="detail-value">
            @if (!string.IsNullOrEmpty(Model.SignedAgreementFilePath))
            {
                <a href="@Model.SignedAgreementFilePath" target="_blank"
                   class="btn-primary" style="padding:6px 14px; font-size:0.85rem;">
                    <i class="fa-solid fa-file-pdf"></i> Download Agreement
                </a>
            }
            else
            {
                <span style="color:var(--text-light);">No agreement uploaded</span>
            }
        </span>
    </div>
</div>

<div class="form-actions" style="border:none; padding-top:0; margin-top:16px;">
    <a asp-action="Index" class="btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> Back to Contracts
    </a>
    <a asp-action="Delete" asp-route-id="@Model.ContractId" class="btn-danger">
        <i class="fa-solid fa-trash"></i> Delete
    </a>
</div>
